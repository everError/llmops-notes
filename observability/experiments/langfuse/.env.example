# =========================================================
# Langfuse self-hosting 환경변수
# 사용법: 이 파일을 .env 로 복사한 뒤 CHANGEME 값을 채운다.
#   생성: openssl rand -base64 32   (SALT, NEXTAUTH_SECRET)
#         openssl rand -hex 32      (ENCRYPTION_KEY — hex 64자 필수)
# docker-compose.yml 은 값이 없으면 기본값(로컬 실습용)으로 동작한다.
# =========================================================

# --- 필수 시크릿 ---
SALT=CHANGEME
ENCRYPTION_KEY=CHANGEME
NEXTAUTH_SECRET=CHANGEME

# --- 초기 시딩 (첫 기동 시 조직/프로젝트/유저/API키 자동 생성) ---
# 이 값들을 설정하면 UI에서 수동으로 프로젝트를 만들 필요 없이
# 노트북에서 바로 아래 키로 연결할 수 있다.
LANGFUSE_INIT_ORG_ID=local-org
LANGFUSE_INIT_ORG_NAME=Local Org
LANGFUSE_INIT_PROJECT_ID=langfuse-lab
LANGFUSE_INIT_PROJECT_NAME=langfuse-lab
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local-0000
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local-CHANGEME
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=CHANGEME

# --- SDK(노트북)에서 사용하는 접속 정보 ---
# 위 INIT 키와 동일한 값을 사용한다.
LANGFUSE_PUBLIC_KEY=pk-lf-local-0000
LANGFUSE_SECRET_KEY=sk-lf-local-CHANGEME
LANGFUSE_HOST=http://localhost:3000

# --- 인프라 비밀번호 (로컬 실습이면 기본값도 무방, 서버 운영 시 변경) ---
# POSTGRES_PASSWORD 를 바꾸면 DATABASE_URL 도 함께 맞춰야 한다.
# POSTGRES_PASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres
# CLICKHOUSE_PASSWORD=clickhouse
# REDIS_AUTH=myredissecret
# MINIO_ROOT_PASSWORD=miniosecret

# --- 기타 ---
TELEMETRY_ENABLED=false
